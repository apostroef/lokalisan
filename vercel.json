{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "excludeFiles": "{node_modules/**,tests/**,resources/js/**,resources/css/**,public/build/**,**/.git/**,**/.github/**,**/.env*,README.md}"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/(css|js|images|favicon.ico)/(.*)", "dest": "/public/$1/$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}